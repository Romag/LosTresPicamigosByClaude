{
  "windowHours": 5,
  "agents": {
    "codex": {
      "displayName": "Codex (ChatGPT)",
      "executable": "codex",
      "model": "gpt",
      "aliases": ["chatgpt"],
      "baseArgs": ["exec", "--color", "never", "--skip-git-repo-check"],
      "promptVia": "stdin",
      "modes": {
        "ask": ["-s", "read-only"],
        "edit": ["-s", "workspace-write"]
      },
      "capabilities": { "implement": 9, "reason": 9, "plan": 8, "review": 8, "test": 8, "docs": 7 },
      "usageParse": "none",
      "limitPatterns": ["(?i)usage limit reached", "(?i)rate.?limit"],
      "timeoutSeconds": 900,
      "maxOutputChars": 200000,
      "enabled": true
    },
    "claude": {
      "displayName": "Claude Code",
      "executable": "claude",
      "model": "claude",
      "aliases": [],
      "baseArgs": ["-p"],
      "promptVia": "stdin",
      "modes": {
        "ask": ["--permission-mode", "plan"],
        "edit": ["--permission-mode", "acceptEdits"]
      },
      "capabilities": { "implement": 9, "reason": 9, "plan": 9, "review": 9, "test": 8, "docs": 8 },
      "usageParse": "none",
      "limitPatterns": ["(?i)usage limit", "(?i)rate limit", "(?i)5-hour limit"],
      "timeoutSeconds": 900,
      "maxOutputChars": 200000,
      "enabled": true
    },
    "antigravity": {
      "displayName": "Antigravity (Gemini 3.5 Flash)",
      "executable": "agy",
      "model": "gemini-3.5-flash",
      "aliases": ["gemini", "agy"],
      "baseArgs": ["--print-timeout", "10m"],
      "promptVia": "arg",
      "modes": {
        "ask": ["--sandbox", "--dangerously-skip-permissions", "-p"],
        "edit": ["--dangerously-skip-permissions", "-p"]
      },
      "capabilities": { "implement": 5, "reason": 6, "plan": 6, "review": 7, "test": 6, "docs": 7 },
      "usageParse": "none",
      "limitPatterns": ["(?i)quota", "(?i)rate limit", "(?i)resource exhausted"],
      "timeoutSeconds": 900,
      "maxOutputChars": 200000,
      "enabled": true,
      "pty": true
    }
  }
}
